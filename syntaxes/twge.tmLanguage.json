{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "twge",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#metadatas"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.twge",
          "match": "\\b(def|block|checks|actions|triggers|if|else|true|false|const|for|in)\\b"
        },
        {
          "name": "keyword.builtin.twge",
          "match": "\\b(Point|ActorMatch|Button|CustomWeapon)\\b"
        },
        {
          "name": "support.function.builtin.twge",
          "match": "\\btwge::(to_string|to_int|to_bool|get_index|get_length|get_slice|assert)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.twge",
      "begin": "\"",
      "end": "\""
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.twge",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.twge",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.block.twge",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "metadatas": {
      "patterns": [
        {
          "name": "metadata.twge",
          "begin": "__",
          "end": "__"
        }
      ]
    }
  },
  "scopeName": "source.twge"
}
